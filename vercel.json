{
  "functions": {
    "app/**/*.tsx": {
      "maxDuration": 30
    },
    "app/api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/cron/abandoned-carts",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/wc-sync",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/cart-recovery",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/review-requests",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/google-reviews",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/deal-rotation",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/gsc-ping",
      "schedule": "0 6 * * *"
    }
  ]
}
