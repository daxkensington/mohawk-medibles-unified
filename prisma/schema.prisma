// ─── Native Cart System ──────────────────────────────────

model CartItem {
    id        Int      @id @default(autoincrement())
    userId    String
    productId Int
    variantId Int?
    quantity  Int      @default(1)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user    User    @relation(fields: [userId], references: [id])
    product Product @relation(fields: [productId], references: [id])

    @@unique([userId, productId, variantId])
    @@index([userId])
    @@index([productId])
}

model AbandonedCart {
    id               Int       @id @default(autoincrement())
    userId           String
    email            String?
    cartSnapshot     Json?
    cartTotal        Float     @default(0)
    emailsSent       Int       @default(0)
    lastEmailSentAt  DateTime?
    recoveredAt      DateTime?
    recoveredOrderId Int?
    status           String    @default("active") // active, recovered, expired
    createdAt        DateTime  @default(now())
    updatedAt        DateTime  @updatedAt

    user           User                @relation(fields: [userId], references: [id])
    recoveryEmails CartRecoveryEmail[]

    @@index([userId])
    @@index([status])
}

model CartRecoveryEmail {
    id              Int       @id @default(autoincrement())
    abandonedCartId Int
    userId          String
    emailNumber     Int
    subject         String
    recipientEmail  String
    discountCode    String?
    discountPercent Int       @default(0)
    cartTotal       Float
    status          String    @default("sent") // sent, opened, clicked, converted
    openedAt        DateTime?
    clickedAt       DateTime?
    convertedAt     DateTime?
    sentAt          DateTime  @default(now())
    subjectVariant  String?   @default("a")

    abandonedCart AbandonedCart @relation(fields: [abandonedCartId], references: [id])

    @@index([abandonedCartId])
}

model CartRecoverySettings {
    id                         Int      @id @default(autoincrement())
    isEnabled                  Boolean  @default(true)
    email1Enabled              Boolean  @default(true)
    email1DelayMinutes         Int      @default(60)
    email1DiscountPercent      Int      @default(0)
    email1Subject              String   @default("You left something behind!")
    email2Enabled              Boolean  @default(true)
    email2DelayMinutes         Int      @default(1440)
    email2DiscountPercent      Int      @default(10)
    email2Subject              String   @default("Your cart is waiting — here's 10% off!")
    email3Enabled              Boolean  @default(true)
    email3DelayMinutes         Int      @default(4320)
    email3DiscountPercent      Int      @default(15)
    email3Subject              String   @default("Last chance — 15% off your cart!")
    maxEmailsPerCart           Int      @default(3)
    cartExpiryDays             Int      @default(7)
    autoGenerateDiscountCodes  Boolean  @default(true)
    discountCodePrefix         String   @default("RECOVER")
    discountCodeExpiryHours    Int      @default(48)
    freeShippingOnRecovery     Boolean  @default(false)
    updatedAt                  DateTime @updatedAt
}

