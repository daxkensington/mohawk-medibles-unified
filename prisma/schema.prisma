    orderNumber   String    @unique
    vendorId      Int
    warehouseId   Int
    status        String    @default("draft") // draft, confirmed, partially_received, received, cancelled
    orderDate     DateTime  @default(now())
    expectedDate  DateTime?
    receivedDate  DateTime?
    totalAmount   Float?    @default(0)
    notes         String?   @db.Text
    createdBy     String?
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt

    vendor    Vendor    @relation(fields: [vendorId], references: [id])
    warehouse Warehouse @relation(fields: [warehouseId], references: [id])
    items     PurchaseOrderItem[]

    @@index([vendorId])
    @@index([status])
}

model PurchaseOrderItem {
    id               Int   @id @default(autoincrement())
    purchaseOrderId  Int
    productId        Int
    quantity         Int
    unitPrice        Float
    totalPrice       Float
    receivedQuantity Int   @default(0)

    purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

    @@index([purchaseOrderId])
}

model SalesOrder {
    id            Int       @id @default(autoincrement())
    orderNumber   String    @unique
    customerId    String
    warehouseId   Int
    status        String    @default("draft") // draft, confirmed, shipped, delivered, cancelled
    orderDate     DateTime  @default(now())
    shippedDate   DateTime?
    deliveredDate DateTime?
    totalAmount   Float?    @default(0)
    notes         String?   @db.Text
    createdBy     String?
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt

    warehouse Warehouse        @relation(fields: [warehouseId], references: [id])
    items     SalesOrderItem[]

    @@index([customerId])
    @@index([status])
}

model SalesOrderItem {
    id              Int   @id @default(autoincrement())
    salesOrderId    Int
    productId       Int
    quantity        Int
    unitPrice       Float
    totalPrice      Float
    shippedQuantity Int   @default(0)

    salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)

    @@index([salesOrderId])
}

model StockAdjustment {
    id              Int      @id @default(autoincrement())
    productId       Int
    warehouseId     Int
    adjustmentType  String   // add, remove, transfer
    quantity        Int
    toWarehouseId   Int?
    reason          String?  @db.Text
    referenceNumber String?
    createdBy       String?
    createdAt       DateTime @default(now())

    warehouse Warehouse @relation(fields: [warehouseId], references: [id])

    @@index([productId])
    @@index([warehouseId])
}

model WarehouseTransfer {
    id                Int       @id @default(autoincrement())
    transferNumber    String    @unique
    fromWarehouseId   Int
    toWarehouseId     Int
    status            String    @default("draft") // draft, pending, approved, in_transit, completed, rejected, cancelled
    priority          String    @default("normal") // low, normal, high, urgent
    requestedBy       String?
    approvedBy        String?
    completedBy       String?
    requestedAt       DateTime?
    approvedAt        DateTime?
    shippedAt         DateTime?
    completedAt       DateTime?
    notes             String?   @db.Text
    rejectionReason   String?   @db.Text
    createdAt         DateTime  @default(now())
    updatedAt         DateTime  @updatedAt

    fromWarehouse Warehouse              @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
    toWarehouse   Warehouse              @relation("TransferTo", fields: [toWarehouseId], references: [id])
    items         WarehouseTransferItem[]

    @@index([fromWarehouseId])
    @@index([toWarehouseId])
    @@index([status])
}

model WarehouseTransferItem {
    id                  Int  @id @default(autoincrement())
    transferId          Int
    productId           Int
    requestedQuantity   Int
    transferredQuantity Int  @default(0)

    transfer WarehouseTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

    @@index([transferId])
}

model ReturnAuthorization {
    id                Int       @id @default(autoincrement())
    rmaNumber         String    @unique
    purchaseOrderId   Int?
    vendorId          Int
    status            String    @default("draft") // draft, pending_approval, approved, shipped, completed, cancelled
    returnType        String    @default("credit") // credit, replacement, repair, write_off
    reason            String?   @db.Text
    notes             String?   @db.Text
    totalCreditAmount Float?    @default(0)
    requestedBy       String?
    approvedBy        String?
    requestedAt       DateTime?
    approvedAt        DateTime?
    shippedAt         DateTime?
    completedAt       DateTime?
    trackingNumber    String?
    createdAt         DateTime  @default(now())
    updatedAt         DateTime  @updatedAt

    vendor Vendor                    @relation(fields: [vendorId], references: [id])
    items  ReturnAuthorizationItem[]

    @@index([vendorId])
    @@index([status])
}

model ReturnAuthorizationItem {
    id           Int    @id @default(autoincrement())
    rmaId        Int
    productId    Int
    quantity     Int
    returnReason String @default("damaged") // damaged, defective, wrong_item, expired, quality_issue
    condition    String @default("damaged")
    resolution   String @default("pending") // credit, replacement, repair, write_off, pending
    creditAmount Float? @default(0)
    notes        String? @db.Text

    rma ReturnAuthorization @relation(fields: [rmaId], references: [id], onDelete: Cascade)

    @@index([rmaId])
}

// ─── Team & Roles ────────────────────────────────────────

model CustomRole {
    id          Int      @id @default(autoincrement())
    name        String   @unique
    description String?  @db.Text
    permissions String   @db.Text // JSON array of permission strings
    baseRole    String?  // inherit from built-in role
    color       String?  @default("gray")
    isActive    Boolean  @default(true)
    createdBy   String?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}

model RoleChangeHistory {
    id        Int      @id @default(autoincrement())
    userId    String
    oldRole   String
    newRole   String
    changedBy String
    reason    String?  @db.Text
    createdAt DateTime @default(now())

    @@index([userId])
}

// ─── BI / Reporting ──────────────────────────────────────

model SiteMonitor {
    id          Int      @id @default(autoincrement())
    name        String
    url         String?
    description String?  @db.Text
    category    String?
    siteType    String   @default("ecommerce") // ecommerce, retail_store, hybrid, warehouse
    color       String?  @default("#3b82f6")
    logoUrl     String?
    isActive    Boolean  @default(true)
    createdBy   String?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    snapshots MetricSnapshot[]
    alerts    BiAlert[]
}

model MetricSnapshot {
    id                  Int       @id @default(autoincrement())
    siteId              Int
    snapshotDate        DateTime
    revenue             Float?
    orders              Int?
    avgOrderValue       Float?
    visitors            Int?
    pageViews           Int?
    bounceRate          Float?
    avgSessionDuration  Int?
    conversionRate      Float?
    organicTraffic      Int?
    inStoreRevenue      Float?
    transactions        Int?
    avgTransactionValue Float?
    footTraffic         Int?
    itemsSold           Int?
    customMetrics       Json?
    source              String    @default("manual") // manual, csv, api
    createdBy           String?
    createdAt           DateTime  @default(now())
    updatedAt           DateTime  @updatedAt

    site SiteMonitor @relation(fields: [siteId], references: [id])

    @@unique([siteId, snapshotDate, source])
    @@index([siteId])
    @@index([snapshotDate])
}

model BiAlert {
    id              Int       @id @default(autoincrement())
    siteId          Int?
    metricName      String
    condition       String    // above, below, change_pct
    threshold       Float
    isEnabled       Boolean   @default(true)
    lastTriggeredAt DateTime?
    createdBy       String?
    createdAt       DateTime  @default(now())
    updatedAt       DateTime  @updatedAt

    site    SiteMonitor?   @relation(fields: [siteId], references: [id])
    history BiAlertHistory[]

    @@index([siteId])
}

model BiAlertHistory {
    id             Int      @id @default(autoincrement())
    alertId        Int
    siteId         Int
    metricName     String
    metricValue    Float
    thresholdValue Float
    message        String?  @db.Text
    isRead         Boolean  @default(false)
    triggeredAt    DateTime @default(now())

    alert BiAlert @relation(fields: [alertId], references: [id])

    @@index([alertId])
    @@index([triggeredAt])
}

model CustomDashboard {
    id           Int      @id @default(autoincrement())
    name         String
    description  String?  @db.Text
    layoutConfig Json?
    isDefault    Boolean  @default(false)
    createdBy    String?
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    widgets DashboardWidget[]
}

model DashboardWidget {
    id           Int      @id @default(autoincrement())
    dashboardId  Int
    widgetType   String
    title        String
    gridPosition Json
    config       Json
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    dashboard CustomDashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

    @@index([dashboardId])
}

// ─── App Settings (KV for command center) ────────────────

model AppSetting {
    id        Int      @id @default(autoincrement())
    key       String   @unique
    value     Json
    updatedAt DateTime @updatedAt
}

// ─── Notification Preferences ────────────────────────────

model NotificationPreference {
    id        Int      @id @default(autoincrement())
    key       String   @unique
    enabled   Boolean  @default(true)
    threshold Float?
    updatedAt DateTime @updatedAt
}

// ─── User Preferences ────────────────────────────────────

model UserPreference {
    id              Int      @id @default(autoincrement())
    userId          String   @unique
    dashboardLayout String?  @db.Text // JSON string of widget order
    updatedAt       DateTime @updatedAt

    user User @relation(fields: [userId], references: [id])
}

// ─── Seasonal Patterns (Demand Forecasting) ──────────────

model SeasonalPattern {
    id               Int      @id @default(autoincrement())
    name             String
    description      String?  @db.Text
    startMonth       Int
    endMonth         Int
    demandMultiplier Float
    color            String?
    isActive         Boolean  @default(true)
    createdBy        String?
    createdAt        DateTime @default(now())
    updatedAt        DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════
// ═══ END MERGED MODELS ════════════════════════════════════
// ═══════════════════════════════════════════════════════════

// ─── WooCommerce Sync Log ──────────────────────────────────

model SyncLog {
    id          String   @id @default(cuid())
    endpoint    String   // "products", "customers", "orders"
    direction   String   @default("wc_to_app") // wc_to_app, app_to_wc
    status      String   // "running", "completed", "failed"
    recordsTotal    Int  @default(0)
    recordsSynced   Int  @default(0)
    recordsFailed   Int  @default(0)
    lastPage        Int  @default(0)
    lastModified    DateTime? // Track modified_after for incremental sync
    error           String?
    startedAt       DateTime @default(now())
    completedAt     DateTime?

    @@index([endpoint])
    @@index([status])
    @@index([startedAt])
}

// ─── Multi-Tenant / Niche Sites ─────────────────────────────

model Tenant {
    id              String   @id @default(cuid())
    slug            String   @unique  // "mohawk-medibles", "unhinged-cannabis"
    name            String             // "Mohawk Medibles"
    domain          String   @unique  // Primary domain: "mohawkmedibles.co"
    altDomains      String[] // Additional domains that resolve to this tenant
    active          Boolean  @default(true)
    isDefault       Boolean  @default(false) // The main Mohawk Medibles site

    // ── Branding ────────────────────────────────────────────
    logoUrl         String?
    faviconUrl      String?
    primaryColor    String   @default("#2D5016")
    secondaryColor  String   @default("#F5E6C8")
    accentColor     String   @default("#D4A574")
    heroTitle       String?
    heroSubtitle    String?
    heroImage       String?
    aboutText       String?

    // ── Product Filters ─────────────────────────────────────
    // Empty arrays = show all products (default tenant behavior)
    categoryFilter  String[] // ["Edibles", "Vapes"] — filter by product category
    subcategoryFilter String[] // finer grain
    tagFilter       String[] // custom product tags
    regionFilter    String[] // regional targeting keywords
    priceMin        Float?
    priceMax        Float?

    // ── SEO ─────────────────────────────────────────────────
    seoTitle        String?
    seoDescription  String?
    seoKeywords     String[]
    ogImage         String?

    // ── Checkout Config ─────────────────────────────────────
    // Payment methods available on this tenant (subset of WC gateways)
    // Empty = all WC payment methods available
    paymentMethods  String[] // ["paygobillingcc", "digipay_etransfer_manual", "wcpg_crypto"]
    checkoutRedirectUrl String? // After payment, redirect here (defaults to tenant domain)
    etransferInstructions String? // Custom e-Transfer instructions per tenant

    // ── Analytics ───────────────────────────────────────────
    gaPropertyId    String?  // Separate GA4 property per tenant

    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt

    // Relations
    analytics       TenantAnalytics[]

    @@index([domain])
    @@index([active])
}

model TenantAnalytics {
    id          String   @id @default(cuid())
    tenantId    String
    date        DateTime @db.Date // One row per tenant per day
    pageViews   Int      @default(0)
    uniqueVisitors Int   @default(0)
    productViews Int     @default(0)
    addToCarts  Int      @default(0)
    checkoutStarts Int   @default(0)
    ordersCompleted Int  @default(0)
    revenue     Float    @default(0)
    avgOrderValue Float  @default(0)

    tenant Tenant @relation(fields: [tenantId], references: [id])

    @@unique([tenantId, date])
    @@index([tenantId])
    @@index([date])
}

// ─── (AbTest consolidated into ABTest above) ────────────

// ─── Session Recording ──────────────────────────────────

model SessionRecording {
    id          String    @id @default(cuid())
    sessionId   String    @unique
    userId      String?
    device      String?
    browser     String?
    entryPage   String?
    exitPage    String?
    duration    Int       @default(0) // milliseconds
    pageCount   Int       @default(0)
    rageClicks  Int       @default(0)
    errorsCount Int       @default(0)
    converted   Boolean   @default(false)
    startedAt   DateTime  @default(now())
    endedAt     DateTime?

    events SessionEvent[]

    @@index([userId])
    @@index([startedAt])
}

model SessionEvent {
    id          Int       @id @default(autoincrement())
    recordingId String
    eventType   String    // click, pageview, error, scroll, input
    page        String?
    elementText String?
    metadata    String?   @db.Text
    timestamp   DateTime  @default(now())

    recording SessionRecording @relation(fields: [recordingId], references: [id], onDelete: Cascade)

    @@index([recordingId])
}

// ─── Fraud Detection ────────────────────────────────────────

model FraudCheck {
    id          String      @id @default(cuid())
    orderId     String
    score       Int         @default(0)   // 0-100
    flags       Json        @default("[]") // JSON array of string reasons
    status      FraudStatus @default(CLEAN)
    reviewedBy  String?     // Admin user ID who reviewed
    reviewedAt  DateTime?
    createdAt   DateTime    @default(now())

    order Order @relation(fields: [orderId], references: [id])

    @@index([orderId])
    @@index([status])
    @@index([score])
    @@index([createdAt])
}

enum FraudStatus {
    CLEAN
    SUSPICIOUS
    BLOCKED
}

// ═══════════════════════════════════════════════════════════
// ═══ AFFILIATE PROGRAM ════════════════════════════════════
// ═══════════════════════════════════════════════════════════

enum AffiliateApplicationStatus {
    PENDING
    APPROVED
    REJECTED
}

enum AffiliateStatus {
    ACTIVE
    PAUSED
    BANNED
}

enum AffiliateConversionStatus {
    PENDING
    APPROVED
    PAID
}

enum AffiliatePayoutStatus {
    PENDING
    COMPLETED
}

enum AffiliatePayoutMethod {
    ETRANSFER
    CRYPTO
}

model AffiliateApplication {
    id          String                     @id @default(cuid())
    userId      String                     @unique
    name        String
    email       String
    website     String?
    socialMedia String?                    // JSON: social media links
    audience    String?                    // Audience size range
    howPromote  String?                    @db.Text
    status      AffiliateApplicationStatus @default(PENDING)
    adminNote   String?
    createdAt   DateTime                   @default(now())
    updatedAt   DateTime                   @updatedAt

    user User @relation(fields: [userId], references: [id])

    @@index([status])
    @@index([createdAt])
}

model Affiliate {
    id             String          @id @default(cuid())
    userId         String          @unique
    code           String          @unique  // e.g. "MOHAWK-JOHN"
    commissionRate Float           @default(10)  // percentage
    totalEarnings  Float           @default(0)
    totalReferrals Int             @default(0)
    totalClicks    Int             @default(0)
    status         AffiliateStatus @default(ACTIVE)
    createdAt      DateTime        @default(now())
    updatedAt      DateTime        @updatedAt

    user        User                  @relation(fields: [userId], references: [id])
    clicks      AffiliateClick[]
    conversions AffiliateConversion[]
    payouts     AffiliatePayout[]

    @@index([code])
    @@index([status])
    @@index([userId])
}

model AffiliateClick {
    id          String   @id @default(cuid())
    affiliateId String
    ip          String?
    userAgent   String?
    referrer    String?
    page        String?
    createdAt   DateTime @default(now())

    affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

    @@index([affiliateId])
    @@index([createdAt])
}

model AffiliateConversion {
    id          String                    @id @default(cuid())
    affiliateId String
    orderId     String
    orderTotal  Float
    commission  Float
    status      AffiliateConversionStatus @default(PENDING)
    createdAt   DateTime                  @default(now())
    updatedAt   DateTime                  @updatedAt

    affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

    @@index([affiliateId])
    @@index([orderId])
    @@index([status])
    @@index([createdAt])
}

model AffiliatePayout {
    id          String                @id @default(cuid())
    affiliateId String
    amount      Float
    method      AffiliatePayoutMethod @default(ETRANSFER)
    status      AffiliatePayoutStatus @default(PENDING)
    note        String?
    createdAt   DateTime              @default(now())
    completedAt DateTime?

    affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

    @@index([affiliateId])
    @@index([status])
    @@index([createdAt])
}

// ─── Google Reviews ──────────────────────────────────────────

model GoogleReview {
    id             String   @id @default(cuid())
    authorName     String
    authorPhoto    String?
    rating         Int      // 1-5
    text           String
    relativeTime   String   // e.g. "2 weeks ago"
    googleReviewId String   @unique
    createdAt      DateTime @default(now())

    @@index([rating])
    @@index([createdAt])
}

model GoogleReviewMeta {
    id            String   @id @default("main") // singleton
    placeId       String
    averageRating Float    @default(0)
    totalReviews  Int      @default(0)
    lastSyncedAt  DateTime @default(now())
}

// ─── Happy Hours (Flash Promotions) ─────────────────────────

model HappyHour {
    id              String   @id @default(cuid())
    name            String
    discountPercent Int      // e.g. 15 = 15% off
    categorySlug    String?  // null = all products
    startHour       Int      // 0-23
    endHour         Int      // 0-23
    daysOfWeek      Json     // array of ints: 0=Sun..6=Sat
    active          Boolean  @default(true)
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt

    @@index([active])
    @@index([categorySlug])
}

// ─── Web Push Notifications ──────────────────────────────────

model PushSubscription {
    id        String   @id @default(cuid())
    userId    String
    endpoint  String   @unique
    p256dh    String
    auth      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([endpoint])
}

// ─── SMS Logs (Twilio Integration) ───────────────────────

model SmsLog {
    id                Int       @id @default(autoincrement())
    phone             String
    message           String    @db.Text
    status            String    @default("QUEUED") // SENT, FAILED, QUEUED
    type              String    // ORDER_CONFIRMATION, SHIPPING_UPDATE, DELIVERY, PROMO, CUSTOM
    orderId           String?
    error             String?   @db.Text
    providerMessageId String?
    createdAt         DateTime  @default(now())

    @@index([status])
    @@index([type])
    @@index([orderId])
    @@index([createdAt])
}

// ─── SMS Opt-In Preferences ─────────────────────────────

model SmsOptIn {
    id        Int      @id @default(autoincrement())
    userId    String   @unique
    phone     String
    optedIn   Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([optedIn])
}

// ─── Wholesale / B2B ────────────────────────────────────────

enum WholesaleBusinessType {
    DISPENSARY
    DELIVERY
    RETAILER
    OTHER
}

enum WholesaleApplicationStatus {
    PENDING
    APPROVED
    REJECTED
}

enum WholesaleTier {
    BRONZE
    SILVER
    GOLD
    PLATINUM
}

enum WholesaleOrderStatus {
    PENDING
    CONFIRMED
    SHIPPED
    DELIVERED
    CANCELLED
}

enum WholesalePaymentStatus {
    UNPAID
    PAID
    OVERDUE
}

model WholesaleApplication {
    id                    String                      @id @default(cuid())
    userId                String                      @unique
    businessName          String
    businessType          WholesaleBusinessType
    taxId                 String?
    website               String?
    phone                 String
    email                 String
    estimatedMonthlyVolume String?
    message               String?                     @db.Text
    status                WholesaleApplicationStatus  @default(PENDING)
    createdAt             DateTime                    @default(now())
    updatedAt             DateTime                    @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([status])
    @@index([createdAt])
}

model WholesaleAccount {
    id              String        @id @default(cuid())
    userId          String        @unique
    businessName    String
    taxId           String?
    tier            WholesaleTier @default(BRONZE)
    discountPercent Int           @default(10)
    creditLimit     Float         @default(0)
    netTerms        Int           @default(0)
    approved        Boolean       @default(true)
    approvedAt      DateTime?
    createdAt       DateTime      @default(now())
    updatedAt       DateTime      @updatedAt

    user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
    orders WholesaleOrder[]

    @@index([tier])
    @@index([approved])
}

model WholesaleOrder {
    id                  String                  @id @default(cuid())
    wholesaleAccountId  String
    orderNumber         String                  @unique
    items               Json
    subtotal            Float
    discount            Float
    total               Float
    status              WholesaleOrderStatus    @default(PENDING)
    paymentStatus       WholesalePaymentStatus  @default(UNPAID)
    paymentDueDate      DateTime?
    notes               String?                 @db.Text
    createdAt           DateTime                @default(now())
    updatedAt           DateTime                @updatedAt

    wholesaleAccount WholesaleAccount @relation(fields: [wholesaleAccountId], references: [id], onDelete: Cascade)

    @@index([wholesaleAccountId])
    @@index([status])
    @@index([paymentStatus])
    @@index([orderNumber])
    @@index([createdAt])
}

// ─── Contests & Giveaways ──────────────────────────────

enum ContestStatus {
    DRAFT
    ACTIVE
    ENDED
}

enum ContestEntryMethod {
    FREE
    PURCHASE
    SIGNUP
    POINTS
}

model Contest {
    id                 Int                @id @default(autoincrement())
    title              String
    description        String             @db.Text
    prize              String
    prizeImage         String?
    entryMethod        ContestEntryMethod @default(FREE)
    minPurchaseAmount  Float?
    pointsCost         Int?               // Points required for POINTS entry method
    startDate          DateTime
    endDate            DateTime
    status             ContestStatus      @default(DRAFT)
    maxEntries         Int?               // Max total entries (null = unlimited)
    winnerId           String?
    winnerAnnouncedAt  DateTime?
    createdAt          DateTime           @default(now())
    updatedAt          DateTime           @updatedAt

    winner  User?          @relation("ContestWinner", fields: [winnerId], references: [id])
    entries ContestEntry[]

    @@index([status])
    @@index([endDate])
}

model ContestEntry {
    id        Int      @id @default(autoincrement())
    contestId Int
    userId    String
    entries   Int      @default(1) // Bonus entries (e.g. each $50 = 1 extra)
    createdAt DateTime @default(now())

    contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
    user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([contestId, userId])
    @@index([contestId])
    @@index([userId])
}

// ─── Gift Tiers (Spending Threshold Rewards) ────────────────

model GiftTier {
    id              Int      @id @default(autoincrement())
    threshold       Float    // Minimum cart total to unlock (e.g. 250.00)
    giftName        String   // e.g. "Free Pre-Roll (1g)"
    giftDescription String   // Short description shown to customers
    giftImage       String?  // Optional image URL
    active          Boolean  @default(true)
    sortOrder       Int      @default(0)
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt

    @@index([active])
    @@index([threshold])
}

// ─── Price Match Requests ─────────────────────────────────────

model PriceMatchRequest {
    id              Int                @id @default(autoincrement())
    userId          String?
    email           String
    productName     String
    competitorUrl   String
    competitorPrice Float
    screenshotUrl   String?
    status          PriceMatchStatus   @default(PENDING)
    adminNote       String?
    matchedPrice    Float?
    createdAt       DateTime           @default(now())
    updatedAt       DateTime           @updatedAt

    user User? @relation(fields: [userId], references: [id])

    @@index([status])
    @@index([email])
    @@index([createdAt])
}

enum PriceMatchStatus {
    PENDING
    APPROVED
    REJECTED
    EXPIRED
}
